import json
import re
from collections import deque

import networkx as nx
import openpyxl

# =========================================================
# OPTIONAL XLWINGS
# =========================================================

try:
    import xlwings as xw
    XLWINGS_AVAILABLE = True
except:
    XLWINGS_AVAILABLE = False

# =========================================================
# CONFIG
# =========================================================

EXCEL_FILE = "sample_euc.xlsx"

OUTPUT_JSON = "semantic_euc.json"

# =========================================================
# LOAD WORKBOOK
# =========================================================

wb = openpyxl.load_workbook(
    EXCEL_FILE,
    data_only=False
)

# =========================================================
# REGEX
# =========================================================

CROSS_SHEET_REGEX = r"(?:'([^']+)'|([A-Za-z0-9_]+))!([A-Z]+[0-9]+)"

CELL_REF_REGEX = r"\b([A-Z]+[0-9]+)\b"

# =========================================================
# GLOBAL GRAPH
# =========================================================

graph = nx.DiGraph()

# =========================================================
# GLOBAL MODEL
# =========================================================

semantic_model = {
    "workbook": EXCEL_FILE,
    "workbook_properties": {},
    "named_ranges": [],
    "pivot_tables": [],
    "sheets": [],
    "lineage": []
}

# =========================================================
# HELPERS
# =========================================================

def extract_dependencies(formula, current_sheet):

    deps = []

    if not formula:
        return deps

    # cross sheet refs
    cross_refs = re.findall(
        CROSS_SHEET_REGEX,
        formula
    )

    for ref in cross_refs:

        sheet = ref[0] if ref[0] else ref[1]

        deps.append({
            "sheet": sheet,
            "cell": ref[2]
        })

    # same sheet refs
    refs = re.findall(
        CELL_REF_REGEX,
        formula
    )

    for ref in refs:

        deps.append({
            "sheet": current_sheet,
            "cell": ref
        })

    # remove duplicates
    unique = []

    seen = set()

    for d in deps:

        key = (
            d["sheet"],
            d["cell"]
        )

        if key not in seen:

            unique.append(d)

            seen.add(key)

    return unique


# =========================================================
# FORMULA AST
# =========================================================

def parse_formula_ast(formula):

    if not formula:
        return None

    formula = formula.replace("=", "")

    functions = re.findall(
        r"([A-Z]+)\(",
        formula
    )

    refs = re.findall(
        CELL_REF_REGEX,
        formula
    )

    operators = re.findall(
        r"[\+\-\*/]",
        formula
    )

    return {
        "raw_formula": formula,
        "functions": functions,
        "references": refs,
        "operators": operators
    }


# =========================================================
# HEADER INFERENCE
# =========================================================

def infer_headers(ws, max_rows=5):

    headers = []

    for r in range(1, max_rows + 1):

        row_vals = []

        for cell in ws[r]:

            row_vals.append(
                str(cell.value)
                if cell.value
                else None
            )

        headers.append(row_vals)

    return headers


def nearest_header(headers, row, col):

    best = None

    best_distance = 999999

    for r_idx, row_data in enumerate(headers):

        for c_idx, value in enumerate(row_data):

            if value:

                dist = abs(row - r_idx) + abs(col - c_idx)

                if dist < best_distance:

                    best_distance = dist

                    best = value

    return best


# =========================================================
# FORMATTING SEMANTICS
# =========================================================

def formatting_semantics(cell):

    semantics = {}

    try:

        fill = cell.fill.fgColor.rgb

        semantics["fill_color"] = fill

        if fill == "FFFFFF00":

            semantics["meaning"] = "INPUT"

        elif fill == "FFFF0000":

            semantics["meaning"] = "OVERRIDE"

        elif fill == "FF00FF00":

            semantics["meaning"] = "OUTPUT"

    except:
        pass

    try:
        semantics["bold"] = cell.font.bold
    except:
        pass

    return semantics


# =========================================================
# BLOCK DETECTION
# =========================================================

def detect_blocks(ws):

    populated = set()

    for row in ws.iter_rows():

        for cell in row:

            if cell.value is not None:

                populated.add(
                    (cell.row, cell.column)
                )

    visited = set()

    directions = [
        (-1,0),
        (1,0),
        (0,-1),
        (0,1)
    ]

    blocks = []

    block_id = 1

    for start in populated:

        if start in visited:
            continue

        queue = deque([start])

        component = []

        visited.add(start)

        while queue:

            r, c = queue.popleft()

            component.append((r,c))

            for dr, dc in directions:

                nr = r + dr
                nc = c + dc

                if (
                    (nr, nc) in populated
                    and (nr, nc) not in visited
                ):

                    visited.add((nr,nc))

                    queue.append((nr,nc))

        rows = [x[0] for x in component]
        cols = [x[1] for x in component]

        min_row = min(rows)
        max_row = max(rows)

        min_col = min(cols)
        max_col = max(cols)

        block_range = (
            f"{openpyxl.utils.get_column_letter(min_col)}"
            f"{min_row}:"
            f"{openpyxl.utils.get_column_letter(max_col)}"
            f"{max_row}"
        )

        blocks.append({
            "block_id": f"BLOCK_{block_id}",
            "range": block_range,
            "cells": component
        })

        block_id += 1

    return blocks


# =========================================================
# BLOCK CLASSIFICATION
# =========================================================

def classify_block(cells):

    total = len(cells)

    formula_count = 0

    numeric_count = 0

    text_count = 0

    for c in cells:

        value = c["value"]

        if c["has_formula"]:
            formula_count += 1

        try:
            float(value)
            numeric_count += 1
        except:
            text_count += 1

    formula_density = (
        formula_count / total
        if total > 0 else 0
    )

    if formula_density > 0.5:
        return "CALCULATION_BLOCK"

    if text_count > numeric_count:
        return "METADATA_BLOCK"

    return "INPUT_OUTPUT_BLOCK"


# =========================================================
# WORKBOOK PROPERTIES
# =========================================================

semantic_model["workbook_properties"] = {
    "sheet_count": len(wb.sheetnames),
    "sheet_names": wb.sheetnames
}

# =========================================================
# NAMED RANGES
# =========================================================

for dn in wb.defined_names.definedName:

    semantic_model["named_ranges"].append({
        "name": dn.name,
        "reference": dn.attr_text
    })

# =========================================================
# SHEET PROCESSING
# =========================================================

for sheet_name in wb.sheetnames:

    ws = wb[sheet_name]

    headers = infer_headers(ws)

    sheet_obj = {
        "sheet_name": sheet_name,
        "hidden": (
            ws.sheet_state != "visible"
        ),
        "headers": headers,
        "blocks": [],
        "tables": [],
        "merged_ranges": []
    }

    # =====================================================
    # TABLES
    # =====================================================

    for table in ws.tables.values():

        sheet_obj["tables"].append({
            "table_name": table.name,
            "range": table.ref
        })

    # =====================================================
    # MERGED CELLS
    # =====================================================

    for merged in ws.merged_cells.ranges:

        sheet_obj["merged_ranges"].append(
            str(merged)
        )

    # =====================================================
    # BLOCKS
    # =====================================================

    blocks = detect_blocks(ws)

    for block in blocks:

        block_cells = []

        for r, c in block["cells"]:

            cell = ws.cell(r, c)

            cell_id = (
                f"{sheet_name}!"
                f"{cell.coordinate}"
            )

            value = cell.value

            has_formula = (
                isinstance(value, str)
                and value.startswith("=")
            )

            dependencies = []

            ast = None

            if has_formula:

                dependencies = extract_dependencies(
                    value,
                    sheet_name
                )

                ast = parse_formula_ast(
                    value
                )

                # graph lineage
                for dep in dependencies:

                    source = (
                        f"{dep['sheet']}!"
                        f"{dep['cell']}"
                    )

                    graph.add_edge(
                        source,
                        cell_id
                    )

            business_context = nearest_header(
                headers,
                cell.row,
                cell.column
            )

            cell_obj = {
                "cell_id": cell_id,
                "coordinate": cell.coordinate,
                "value": str(value),
                "data_type": str(cell.data_type),
                "has_formula": has_formula,
                "formula": (
                    str(value)
                    if has_formula
                    else None
                ),
                "formula_ast": ast,
                "dependencies": dependencies,
                "business_context": business_context,
                "comment": (
                    cell.comment.text
                    if cell.comment
                    else None
                ),
                "formatting": formatting_semantics(cell)
            }

            block_cells.append(
                cell_obj
            )

        block_type = classify_block(
            block_cells
        )

        sheet_obj["blocks"].append({

            "block_id": block["block_id"],

            "range": block["range"],

            "block_type": block_type,

            "cell_count": len(block_cells),

            "cells": block_cells
        })

    semantic_model["sheets"].append(
        sheet_obj
    )

# =========================================================
# LINEAGE
# =========================================================

for edge in graph.edges():

    semantic_model["lineage"].append({
        "source": edge[0],
        "target": edge[1]
    })

# =========================================================
# PIVOT EXTRACTION
# =========================================================

if XLWINGS_AVAILABLE:

    try:

        app = xw.App(
            visible=False
        )

        xwb = xw.Book(EXCEL_FILE)

        for sheet in xwb.sheets:

            try:

                pivots = sheet.api.PivotTables()

                for pivot in pivots:

                    pivot_obj = {
                        "sheet": sheet.name,
                        "pivot_name": pivot.Name,
                        "source_data": None,
                        "row_fields": [],
                        "column_fields": [],
                        "filters": [],
                        "data_fields": []
                    }

                    try:
                        pivot_obj["source_data"] = (
                            pivot.SourceData
                        )
                    except:
                        pass

                    # row fields
                    try:

                        for i in range(
                            1,
                            pivot.RowFields().Count + 1
                        ):

                            field = pivot.RowFields(i)

                            pivot_obj[
                                "row_fields"
                            ].append(
                                field.Name
                            )

                    except:
                        pass

                    # column fields
                    try:

                        for i in range(
                            1,
                            pivot.ColumnFields().Count + 1
                        ):

                            field = pivot.ColumnFields(i)

                            pivot_obj[
                                "column_fields"
                            ].append(
                                field.Name
                            )

                    except:
                        pass

                    # filters
                    try:

                        for i in range(
                            1,
                            pivot.PageFields().Count + 1
                        ):

                            field = pivot.PageFields(i)

                            pivot_obj[
                                "filters"
                            ].append(
                                field.Name
                            )

                    except:
                        pass

                    # data fields
                    try:

                        for i in range(
                            1,
                            pivot.DataFields().Count + 1
                        ):

                            field = pivot.DataFields(i)

                            pivot_obj[
                                "data_fields"
                            ].append({
                                "name": field.Name,
                                "function": field.Function
                            })

                    except:
                        pass

                    semantic_model[
                        "pivot_tables"
                    ].append(
                        pivot_obj
                    )

            except:
                pass

        xwb.close()

        app.quit()

    except Exception as e:

        print(
            f"Pivot extraction failed: {e}"
        )

# =========================================================
# SAVE JSON
# =========================================================

with open(
    OUTPUT_JSON,
    "w",
    encoding="utf-8"
) as f:

    json.dump(
        semantic_model,
        f,
        indent=4
    )

# =========================================================
# SUMMARY
# =========================================================

print("=" * 60)
print("FULL ENTERPRISE EUC EXTRACTION COMPLETE")
print("=" * 60)

print(f"Workbook: {EXCEL_FILE}")

print(
    f"Sheets: "
    f"{len(semantic_model['sheets'])}"
)

print(
    f"Named Ranges: "
    f"{len(semantic_model['named_ranges'])}"
)

print(
    f"Pivots: "
    f"{len(semantic_model['pivot_tables'])}"
)

print(
    f"Lineage Edges: "
    f"{len(semantic_model['lineage'])}"
)

print(f"\nOutput: {OUTPUT_JSON}")

print("\nWorkbook converted into semantic LLM context.")
